{
  "name": "samsung-tv-control",
  "version": "0.2.0",
  "description": "Wake a Samsung TV and switch its input to PC over the LAN (Wake-on-LAN + remote WebSocket), with optional SmartThings cloud control.",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timdevlet/samsung-tv-control.git"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "start:mock": "SMARTTHINGS_MOCK=1 tsx src/cli.ts",
    "off": "tsx src/cli.ts --off",
    "off:mock": "SMARTTHINGS_MOCK=1 tsx src/cli.ts --off",
    "login": "tsx src/cli.ts --login",
    "devices": "tsx src/cli.ts --devices",
    "devices:mock": "SMARTTHINGS_MOCK=1 tsx src/cli.ts --devices",
    "reset": "tsx src/cli.ts --reset",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.renderer.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:build": "node scripts/build-electron.mjs",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:dev:mock": "node scripts/electron-dev.mjs --mock",
    "sync-version": "node scripts/sync-version.mjs",
    "dist": "npm run sync-version && npm run electron:build && electron-builder",
    "dist:win": "npm run sync-version && npm run electron:build && electron-builder --win",
    "dist:dir": "npm run sync-version && npm run electron:build && electron-builder --dir"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "overlayscrollbars": "^2.16.0",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass-embedded": "^1.100.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.timdevlet.samsung-tv-control",
    "productName": "Samsung TV Control",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Samsung TV Control",
      "artifactName": "${productName} Setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "dmg": {
      "artifactName": "${productName}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "ws": "^8.21.1"
  }
}
